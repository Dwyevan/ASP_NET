@model IEnumerable<Cms.data.Entities.Order>
@{
    // ÁP DỤNG LAYOUT ADMIN CHO ĐỒNG BỘ HỆ THỐNG
    Layout = "_LayoutAdmin";
}
<div class="container mt-4">

    <h2 class="text-success fw-bold mb-4">
        DANH SÁCH ĐƠN HÀNG
    </h2>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Khách hàng</th> @* Sửa tiêu đề từ CustomerId thành Khách hàng *@
                        <th>Order Date</th>
                        <th>Total</th>
                        <th style="width: 150px;">Chức năng</th> @* Thêm cột Chức năng để chứa nút bấm *@
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">#@item.Id</td>

                                <td>
                                    @if (item.Customer != null)
                                    {
                                        <span class="fw-bold text-dark">@item.Customer.FullName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Ẩn danh</span>
                                    }
                                </td>

                                <td class="text-center">
                                    @item.OrderDate.ToString("dd/MM/yyyy HH:mm")
                                </td>

                                <td class="text-danger fw-bold text-end pe-3">
                                    @item.TotalAmount.ToString("#,##0") đ
                                </td>

                                <td class="text-center">
                                    <a asp-action="Details"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info fw-bold text-dark">
                                        Xem chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-danger fw-bold py-4">
                                Chưa có đơn hàng nào trong hệ thống!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>