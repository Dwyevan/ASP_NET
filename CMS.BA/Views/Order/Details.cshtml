@model Cms.data.Entities.Order
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-uppercase mb-0 text-primary">
            <i class="bi bi-receipt me-2"></i>CHI TIẾT ĐƠN HÀNG #@Model.Id
        </h4>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <!-- Cột trái: Thông tin sản phẩm -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white p-3 border-bottom-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-box-seam me-2"></i>Danh sách sản phẩm</h5>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width: 100px;">Hình ảnh</th>
                                    <th class="text-start">Sản phẩm</th>
                                    <th style="width: 120px;">Đơn giá</th>
                                    <th style="width: 80px;">SL</th>
                                    <th style="width: 150px;" class="text-end pe-4">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.OrderDetails != null && Model.OrderDetails.Any())
                                {
                                    decimal totalSum = 0;
                                    foreach (var item in Model.OrderDetails)
                                    {
                                        var productTotal = item.UnitPrice * item.Quantity;
                                        totalSum += productTotal;
                                        <tr>
                                            <td class="text-center p-2">
                                                @if (item.Product != null && !string.IsNullOrEmpty(item.Product.ImageUrl))
                                                {
                                                    <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="img-thumbnail border-0 shadow-sm rounded" style="width: 60px; height: 60px; object-fit: cover;" />
                                                }
                                                else
                                                {
                                                    <img src="/images/wine-placeholder.png" alt="No image" class="img-thumbnail border-0 shadow-sm rounded" style="width: 60px; height: 60px; object-fit: cover;" />
                                                }
                                            </td>
                                            <td class="text-start fw-bold text-dark">
                                                @(item.Product != null ? item.Product.Name : "Sản phẩm không tồn tại")
                                            </td>
                                            <td class="text-center text-muted">
                                                @String.Format("{0:N0} ₫", item.UnitPrice)
                                            </td>
                                            <td class="text-center fw-bold">
                                                x @item.Quantity
                                            </td>
                                            <td class="text-end pe-4 fw-bold text-danger">
                                                @String.Format("{0:N0} ₫", productTotal)
                                            </td>
                                        </tr>
                                    }
                                    <tr class="table-light">
                                        <td colspan="4" class="text-end fw-bold fs-5">TỔNG CỘNG:</td>
                                        <td class="text-end pe-4 fw-bold fs-5 text-danger">
                                            @String.Format("{0:N0} ₫", totalSum)
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-5">
                                            Không có sản phẩm nào!
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cột phải: Thông tin Khách hàng & Trạng thái -->
        <div class="col-lg-4">
            <div class="card shadow-sm border-0 rounded-3 mb-4">
                <div class="card-header bg-white p-3 border-bottom-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-person-lines-fill me-2"></i>Thông tin Khách hàng</h5>
                </div>
                <div class="card-body bg-light">
                    @if (Model.Customer != null)
                    {
                        <p class="mb-2"><i class="bi bi-person-fill text-muted me-2"></i><strong>@Model.Customer.FullName</strong></p>
                        <p class="mb-2"><i class="bi bi-telephone-fill text-muted me-2"></i><a href="tel:@Model.Customer.Phone" class="text-decoration-none">@Model.Customer.Phone</a></p>
                        <p class="mb-2"><i class="bi bi-envelope-fill text-muted me-2"></i><a href="mailto:@Model.Customer.Email" class="text-decoration-none">@Model.Customer.Email</a></p>
                        <p class="mb-0 mt-3 border-top pt-3"><i class="bi bi-geo-alt-fill text-danger me-2"></i><strong>Địa chỉ giao hàng:</strong><br />@Model.Customer.Address</p>
                    }
                    else
                    {
                        <p class="text-muted fst-italic">Khách vãng lai (Ẩn danh)</p>
                    }
                </div>
            </div>

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white p-3 border-bottom-0">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-info-circle-fill me-2"></i>Tình trạng đơn hàng</h5>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(ViewBag.CancelReason as string))
                    {
                        <div class="alert alert-danger shadow-sm border-danger p-3 mb-4">
                            <h6 class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-2"></i>Lý do khách hàng Hủy:</h6>
                            <p class="mb-0 fs-6 fst-italic">"@ViewBag.CancelReason"</p>
                        </div>
                    }

                    <p class="mb-3"><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm:ss")</p>
                    <p class="mb-4">
                        <strong>Trạng thái:</strong> 
                        @if (Model.Status == 0)
                        {
                            <span class="badge rounded-pill bg-warning text-dark fs-6 ms-2">Chờ duyệt (COD)</span>
                        }
                        else if (Model.Status == 1)
                        {
                            <span class="badge rounded-pill bg-info text-dark fs-6 ms-2">Đang giao (COD)</span>
                        }
                        else if (Model.Status == 2)
                        {
                            <span class="badge rounded-pill bg-success fs-6 ms-2">Đã xong (COD)</span>
                        }
                        else if (Model.Status == 3)
                        {
                            <span class="badge rounded-pill bg-secondary fs-6 ms-2">Đã hủy</span>
                        }
                        else if (Model.Status == 10)
                        {
                            <span class="badge rounded-pill bg-warning text-dark fs-6 ms-2">Chờ duyệt (MoMo)</span>
                        }
                        else if (Model.Status == 11)
                        {
                            <span class="badge rounded-pill bg-info text-dark fs-6 ms-2">Đang giao (MoMo)</span>
                        }
                        else if (Model.Status == 12)
                        {
                            <span class="badge rounded-pill bg-success fs-6 ms-2">Đã xong (MoMo)</span>
                        }
                        else if (Model.Status == 13)
                        {
                            <span class="badge rounded-pill bg-danger fw-bold border border-danger shadow-sm fs-6 ms-2" style="animation: pulse 1.5s infinite;">YÊU CẦU HOÀN TIỀN</span>
                        }
                        else if (Model.Status == 14)
                        {
                            <span class="badge rounded-pill bg-secondary text-white fs-6 ms-2">Đã hoàn tiền</span>
                        }
                    </p>

                    <!-- Thao tác thay đổi trạng thái ngay trong trang chi tiết -->
                    <div class="d-grid gap-2">
                        @if (Model.Status == 0) // Chờ duyệt COD
                        {
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="1" />
                                <button type="submit" class="btn btn-warning fw-bold text-dark mb-2" onclick="return confirm('Xác nhận duyệt và giao hàng?');">
                                    <i class="bi bi-truck me-2"></i>Duyệt đơn & Giao hàng
                                </button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="3" />
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Xác nhận hủy đơn hàng này?');">
                                    <i class="bi bi-x-circle me-2"></i>Hủy đơn hàng
                                </button>
                            </form>
                        }
                        else if (Model.Status == 10) // Chờ duyệt MoMo
                        {
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="11" />
                                <button type="submit" class="btn btn-warning fw-bold text-dark mb-2" onclick="return confirm('Xác nhận duyệt và giao hàng?');">
                                    <i class="bi bi-truck me-2"></i>Duyệt đơn & Giao hàng
                                </button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="13" />
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Hủy đơn và chuyển sang Yêu cầu hoàn tiền?');">
                                    <i class="bi bi-x-circle me-2"></i>Chuyển Yêu cầu Hoàn tiền
                                </button>
                            </form>
                        }
                        else if (Model.Status == 1) // Đang giao COD
                        {
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="2" />
                                <button type="submit" class="btn btn-success fw-bold mb-2" onclick="return confirm('Xác nhận khách đã nhận hàng thành công?');">
                                    <i class="bi bi-check-circle me-2"></i>Xác nhận Giao xong
                                </button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="3" />
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Xác nhận hủy đơn vì giao hàng thất bại?');">
                                    <i class="bi bi-x-circle me-2"></i>Khách bom hàng (Hủy)
                                </button>
                            </form>
                        }
                        else if (Model.Status == 11) // Đang giao MoMo
                        {
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="12" />
                                <button type="submit" class="btn btn-success fw-bold mb-2" onclick="return confirm('Xác nhận khách đã nhận hàng thành công?');">
                                    <i class="bi bi-check-circle me-2"></i>Xác nhận Giao xong
                                </button>
                            </form>
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="13" />
                                <button type="submit" class="btn btn-outline-danger" onclick="return confirm('Xác nhận hủy đơn vì giao hàng thất bại (Yêu cầu hoàn tiền)?');">
                                    <i class="bi bi-x-circle me-2"></i>Khách bom hàng (Chờ Hoàn Tiền)
                                </button>
                            </form>
                        }
                        else if (Model.Status == 13) // YÊU CẦU HOÀN TIỀN
                        {
                            <div class="alert alert-danger p-2 mb-3 text-center" style="font-size: 0.9rem;">
                                Khách hàng yêu cầu hoàn tiền cho đơn đã thanh toán MoMo. Vui lòng chuyển khoản lại cho khách và bấm nút Xác nhận bên dưới.
                            </div>
                            <form asp-action="UpdateStatus" method="post" class="m-0 d-grid">
                                <input type="hidden" name="id" value="@Model.Id" />
                                <input type="hidden" name="status" value="14" />
                                <button type="submit" class="btn btn-danger fw-bold shadow-sm" onclick="return confirm('Bạn XÁC NHẬN ĐÃ CHUYỂN KHOẢN hoàn tiền lại cho khách hàng?');">
                                    <i class="bi bi-cash-coin me-2"></i>Xác nhận Đã Hoàn Tiền
                                </button>
                            </form>
                        }
                    </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>