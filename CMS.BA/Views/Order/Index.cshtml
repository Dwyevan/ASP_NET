@model IEnumerable<Cms.data.Entities.Order>
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white p-3 border-bottom-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-primary text-uppercase mb-0">
                <i class="bi bi-cart-check-fill me-2"></i>DANH SÁCH ĐƠN HÀNG
            </h5>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th class="text-start">Khách hàng</th>
                            <th class="text-center">Ngày đặt</th>
                            <th class="text-end pe-4">Tổng tiền</th>
                            <th class="text-center">Trạng thái</th>
                            <th style="width: 120px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-secondary">#@item.Id</td>
                                    <td class="text-start">
                                        @if (item.Customer != null)
                                        {
                                            <span class="fw-bold text-dark">@item.Customer.FullName</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Ẩn danh</span>
                                        }
                                    </td>
                                    <td class="text-center text-muted">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="text-end pe-4 text-danger fw-bold">
                                        @String.Format("{0:N0} ₫", item.TotalAmount)
                                    </td>
                                    <td class="text-center">
                                        @if (item.Status == 0)
                                        {
                                            <span class="badge rounded-pill bg-warning text-dark">Chờ duyệt</span>
                                        }
                                        else if (item.Status == 1)
                                        {
                                            <span class="badge rounded-pill bg-info text-dark">Đang giao</span>
                                        }
                                        else if (item.Status == 2)
                                        {
                                            <span class="badge rounded-pill bg-success">Đã xong</span>
                                        }
                                        else
                                        {
                                            <span class="badge rounded-pill bg-secondary">Không rõ</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white shadow-sm" title="Chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    <h5>Chưa có đơn hàng nào trong hệ thống!</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>