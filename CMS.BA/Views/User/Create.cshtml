@model Cms.data.Entities.User

<div class="container mt-4">

    <h2>THÊM USER</h2>

    <form asp-action="Create" method="post">

        <div class="mb-3">

            <label>Username</label>

            <input asp-for="Username"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>Password</label>

            <input asp-for="PasswordHash"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>Full Name</label>

            <input asp-for="FullName"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label>Role</label>

            <input asp-for="Role"
                   class="form-control" />

        </div>

        <button class="btn btn-success">

            Lưu User

        </button>

        <a asp-action="Index"
           class="btn btn-secondary">

            Quay lại

        </a>

    </form>

</div>