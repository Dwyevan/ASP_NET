@model IEnumerable<Cms.data.Entities.User>
@{
    Layout = "_LayoutAdmin";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 rounded">
        <div class="card-header bg-white p-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-dark mb-0">QUẢN LÝ TÀI KHOẢN</h5>
            <a asp-action="Create" class="btn btn-success btn-sm">
                <i class="bi bi-person-plus"></i> Thêm thành viên mới
            </a>
        </div>
        <div class="card-body">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-dark">
                    <tr>
                        <th style="width:70px">ID</th>
                        <th class="text-start">Username</th>
                        <th>Mật khẩu</th>
                        <th class="text-start">Full Name</th>
                        <th style="width:140px">Role</th>
                        <th style="width:150px">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td class="fw-semibold text-start">@item.Username</td>
                                <td>
                                    <span class="text-muted" style="letter-spacing: 2px;">••••••••</span>
                                </td>
                                <td class="text-start">@item.FullName</td>
                                <td>
                                    @if (item.Role == "Admin")
                                    {
                                        <span class="badge bg-danger">@item.Role</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-info text-dark">@item.Role</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle shadow-sm" type="button" id="actionMenu-@item.Id" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-gear"></i> Thao tác
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="actionMenu-@item.Id" style="min-width: 150px;">
                                            <li>
                                                <a asp-action="Edit" asp-route-id="@item.Id" class="dropdown-item text-warning py-2 fw-bold">
                                                    <i class="bi bi-pencil-square me-2"></i>Chỉnh sửa
                                                </a>
                                            </li>
                                            <li><hr class="dropdown-divider"></li>
                                            <li>
                                                <a asp-action="Delete" asp-route-id="@item.Id" class="dropdown-item text-danger py-2" onclick="return confirm('Bạn có chắc muốn xóa User này?')">
                                                    <i class="bi bi-trash me-2"></i>Xóa tài khoản
                                                </a>
                                            </li>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-muted py-3">Không có dữ liệu User</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>