@model IEnumerable<Cms.data.Entities.Post>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Bài viết";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm rounded-3 border-0">
        <div class="card-header bg-white p-3 border-bottom-0">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0 text-primary text-uppercase">
                    <i class="bi bi-file-earmark-text me-2"></i>QUẢN LÝ BÀI VIẾT
                </h4>
                
                <div class="d-flex gap-3 align-items-center">
                    <!-- Search Bar -->
                    <form class="d-flex" asp-action="Index" method="get">
                        <div class="input-group input-group-sm">
                            <input type="text" name="keyword" class="form-control" placeholder="Tìm kiếm bài viết..." aria-label="Tìm kiếm">
                            <button class="btn btn-outline-secondary" type="submit" title="Tìm kiếm">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                    
                    <!-- Nút Viết bài mới -->
                    <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm text-nowrap">
                        <i class="bi bi-plus-circle me-1"></i> Viết bài mới
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="p-4">
                <div class="row">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <div class="col-md-4 mb-4">
                                <div class="card shadow-sm h-100 d-flex flex-column">
                                    <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="width: 100%; height: 200px; object-fit: cover; object-position: center;" onerror="this.onerror=null;this.src='https://placehold.co/600x400?text=No+Image';" />
                                    <div class="card-body flex-grow-1">
                                        <span class="badge bg-info text-white mb-2">@(item.Category != null ? item.Category.Name : "Không có")</span>
                                        <h5 class="card-title fw-bold text-dark">@item.Title</h5>
                                        <p class="card-text text-muted" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal;">@item.Content</p>
                                        <p class="card-text"><small class="text-muted"><i class="bi bi-clock me-1"></i>@item.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small></p>
                                    </div>
                                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-between align-items-center">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white shadow-sm" title="Xem chi tiết"><i class="bi bi-eye"></i> Xem</a>
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-dark shadow-sm" title="Chỉnh sửa"><i class="bi bi-pencil-square"></i> Sửa</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm shadow-sm" title="Xóa bài viết" onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này không?');"><i class="bi bi-trash"></i> Xóa</a>
                                    </div>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="col-12 text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary opacity-50"></i>
                            <h5>Chưa có bài viết nào trong hệ thống.</h5>
                            <p class="mb-0">Hãy nhấn "Viết bài mới" để tạo bài viết đầu tiên!</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>