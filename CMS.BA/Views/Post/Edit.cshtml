@model Cms.data.Entities.Post
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white p-3 border-bottom">
                    <h5 class="fw-bold text-dark mb-0">CHỈNH SỬA BÀI VIẾT</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="CreatedDate" />
                        
                        <div asp-validation-summary="All" class="text-danger mb-3 fw-bold"></div>
                        
                        <div class="mb-3">
                            <label asp-for="Title" class="form-label fw-bold text-dark">Tiêu đề bài viết</label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề bài viết..." />
                        </div>
                        <div class="mb-3">
                            <label asp-for="CategoryId" class="form-label fw-bold text-dark">Danh mục bài viết</label>
                            <select asp-for="CategoryId" class="form-select">
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var c in ViewBag.Categories)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label asp-for="Content" class="form-label fw-bold text-dark">Nội dung bài viết</label>
                            <textarea asp-for="Content" rows="6" class="form-control" placeholder="Nhập nội dung chi tiết bài viết..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-bold text-dark">Ảnh URL</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="Ví dụ: /img/dotnet.jpg (Có thể để trống)" />
                            @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                            {
                                <div class="mt-2">
                                    <img src="@Model.ImageUrl" alt="Current Image" style="max-height: 100px; border: 1px solid #ccc; border-radius: 5px;" />
                                </div>
                            }
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold text-dark">Hoặc tải ảnh lên từ máy tính</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>