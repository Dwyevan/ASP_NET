@{
    // Ép trang chủ sử dụng giao diện Admin có thanh Sidebar bên trái
    Layout = "_LayoutAdmin";
}

<style>
    .hover-elevate { transition: transform 0.3s ease, box-shadow 0.3s ease; }
    .hover-elevate:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; }
    
    /* Gradients for Stat Cards */
    .bg-gradient-primary { background: linear-gradient(135deg, #4e73df 0%, #224abe 100%); color: white; }
    .bg-gradient-success { background: linear-gradient(135deg, #1cc88a 0%, #13855c 100%); color: white; }
    .bg-gradient-info { background: linear-gradient(135deg, #36b9cc 0%, #258391 100%); color: white; }
    .bg-gradient-warning { background: linear-gradient(135deg, #f6c23e 0%, #dda20a 100%); color: white; }

    .stat-icon { font-size: 3.5rem; opacity: 0.3; transition: all 0.3s ease; }
    .hover-elevate:hover .stat-icon { transform: scale(1.1) rotate(5deg); opacity: 0.5; }
    
    .table-hover tbody tr:hover { background-color: #f8f9fa; }
    
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;  
        overflow: hidden;
    }
</style>

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold text-dark mb-0">Bảng điều khiển</h3>
        <span class="text-muted"><i class="bi bi-clock me-1"></i> Cập nhật lúc: @DateTime.Now.ToString("HH:mm dd/MM/yyyy")</span>
    </div>

    <!-- Khu vực 1: 4 Thẻ Thống Kê -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-gradient-primary border-0 shadow-sm rounded-4 h-100 hover-elevate position-relative overflow-hidden">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-white z-index-1">
                            <div class="text-uppercase small fw-bold mb-1 opacity-75">Tổng Sản Phẩm</div>
                            <div class="fs-1 fw-bold">@ViewBag.TotalProducts</div>
                            <div class="mt-2 small opacity-75"><i class="bi bi-arrow-up-circle me-1"></i> Đang hoạt động</div>
                        </div>
                        <i class="bi bi-box-seam position-absolute bottom-0 end-0 m-3 stat-icon text-white"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-gradient-success border-0 shadow-sm rounded-4 h-100 hover-elevate position-relative overflow-hidden">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-white z-index-1">
                            <div class="text-uppercase small fw-bold mb-1 opacity-75">Đơn Hàng</div>
                            <div class="fs-1 fw-bold">@ViewBag.TotalOrders</div>
                            <div class="mt-2 small">
                                @if (ViewBag.PendingOrdersCount != null && ViewBag.PendingOrdersCount > 0)
                                {
                                    <span class="badge bg-white text-success px-2 py-1"><i class="bi bi-exclamation-circle me-1"></i> @ViewBag.PendingOrdersCount chờ duyệt</span>
                                }
                                else
                                {
                                    <span class="opacity-75"><i class="bi bi-check-circle me-1"></i> Tất cả đã xử lý</span>
                                }
                            </div>
                        </div>
                        <i class="bi bi-cart-check position-absolute bottom-0 end-0 m-3 stat-icon text-white"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-gradient-info border-0 shadow-sm rounded-4 h-100 hover-elevate position-relative overflow-hidden">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-white z-index-1">
                            <div class="text-uppercase small fw-bold mb-1 opacity-75">Khách Hàng</div>
                            <div class="fs-1 fw-bold">@ViewBag.TotalCustomers</div>
                            <div class="mt-2 small opacity-75"><i class="bi bi-people-fill me-1"></i> Thành viên hệ thống</div>
                        </div>
                        <i class="bi bi-people position-absolute bottom-0 end-0 m-3 stat-icon text-white"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="card bg-gradient-warning border-0 shadow-sm rounded-4 h-100 hover-elevate position-relative overflow-hidden">
                <div class="card-body py-4">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-white z-index-1">
                            <div class="text-uppercase small fw-bold mb-1 opacity-75">Tổng Doanh Thu</div>
                            <div class="fs-2 fw-bold">@String.Format("{0:N0}", ViewBag.TotalRevenue ?? 0) <span class="fs-5">₫</span></div>
                            <div class="mt-2 small opacity-75"><i class="bi bi-graph-up-arrow me-1"></i> Lợi nhuận gộp</div>
                        </div>
                        <i class="bi bi-currency-dollar position-absolute bottom-0 end-0 m-3 stat-icon text-white"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Khu vực 2: Dữ liệu chi tiết & Thao tác nhanh -->
    <div class="row">
        <!-- CỘT TRÁI: Bảng đơn hàng -->
        <div class="col-xl-8 mb-4">
            <div class="card border-0 shadow-sm rounded-4 h-100">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-3 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-receipt me-2 text-primary"></i> ĐƠN HÀNG MỚI NHẤT</h5>
                    <a href="/Order/Index" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem tất cả</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-muted small text-uppercase">
                                <tr>
                                    <th class="ps-4">Mã ĐH</th>
                                    <th>Khách hàng</th>
                                    <th>Ngày đặt</th>
                                    <th>Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th class="text-end pe-4">Thao tác</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (ViewBag.RecentOrders != null)
                                {
                                    foreach (var order in ViewBag.RecentOrders)
                                    {
                                        <tr>
                                            <td class="ps-4 fw-bold text-secondary">#@order.Id</td>
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="avatar bg-light text-primary rounded-circle me-2 d-flex justify-content-center align-items-center fw-bold" style="width:32px; height:32px; font-size: 0.8rem;">
                                                        @(order.Customer != null && !string.IsNullOrEmpty(order.Customer.FullName) ? order.Customer.FullName.Substring(0, 1).ToUpper() : "K")
                                                    </div>
                                                    <span class="fw-semibold">@(order.Customer != null ? order.Customer.FullName : "Khách vãng lai")</span>
                                                </div>
                                            </td>
                                            <td class="text-muted small">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="fw-bold text-dark">@String.Format("{0:N0} ₫", order.TotalAmount)</td>
                                            <td>
                                                @if (order.Status == 0)
                                                {
                                                    <span class="badge bg-warning text-dark px-2 py-1 rounded-pill"><i class="bi bi-hourglass-split me-1"></i> Chờ duyệt (COD)</span>
                                                }
                                                else if (order.Status == 1)
                                                {
                                                    <span class="badge bg-info text-dark px-2 py-1 rounded-pill"><i class="bi bi-truck me-1"></i> Đang giao (COD)</span>
                                                }
                                                else if (order.Status == 2)
                                                {
                                                    <span class="badge bg-success px-2 py-1 rounded-pill"><i class="bi bi-check-circle me-1"></i> Đã xong (COD)</span>
                                                }
                                                else if (order.Status == 3)
                                                {
                                                    <span class="badge bg-secondary px-2 py-1 rounded-pill"><i class="bi bi-x-circle me-1"></i> Đã hủy</span>
                                                }
                                                else if (order.Status == 10)
                                                {
                                                    <span class="badge bg-success px-2 py-1 rounded-pill"><i class="bi bi-wallet2 me-1"></i> Đã thanh toán (MoMo)</span>
                                                }
                                                else if (order.Status == 11)
                                                {
                                                    <span class="badge bg-info text-dark px-2 py-1 rounded-pill"><i class="bi bi-truck me-1"></i> Đang giao (MoMo)</span>
                                                }
                                                else if (order.Status == 12)
                                                {
                                                    <span class="badge bg-success px-2 py-1 rounded-pill"><i class="bi bi-check-circle me-1"></i> Đã xong (MoMo)</span>
                                                }
                                                else if (order.Status == 13)
                                                {
                                                    <span class="badge bg-danger px-2 py-1 rounded-pill fw-bold" style="animation: pulse 1.5s infinite;"><i class="bi bi-exclamation-triangle me-1"></i> YÊU CẦU HOÀN TIỀN</span>
                                                }
                                                else if (order.Status == 14)
                                                {
                                                    <span class="badge bg-secondary px-2 py-1 rounded-pill"><i class="bi bi-cash-coin me-1"></i> Đã hoàn tiền</span>
                                                }
                                                else if (order.Status == -1)
                                                {
                                                    <span class="badge bg-danger px-2 py-1 rounded-pill"><i class="bi bi-x-octagon me-1"></i> Thanh toán thất bại</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-secondary px-2 py-1 rounded-pill">Không rõ</span>
                                                }
                                            </td>
                                            <td class="text-end pe-4">
                                                <a href="/Order/Details/@order.Id" class="btn btn-sm btn-light border rounded-circle" title="Xem chi tiết">
                                                    <i class="bi bi-eye text-primary"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-5">
                                            <i class="bi bi-inbox fs-2 d-block mb-2 text-light"></i>
                                            Chưa có đơn hàng nào
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- CỘT PHẢI: Thao tác & Sản phẩm mới -->
        <div class="col-xl-4 mb-4">
            <!-- THAO TÁC NHANH -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-lightning-charge me-2 text-warning"></i> THAO TÁC NHANH</h5>
                </div>
                <div class="card-body gap-3 d-grid">
                    <a href="/Product/Create" class="btn btn-primary d-flex justify-content-between align-items-center py-2 px-3 rounded-3 shadow-sm hover-elevate">
                        <span class="fw-semibold"><i class="bi bi-plus-circle me-2"></i> Thêm Sản Phẩm</span>
                        <i class="bi bi-chevron-right opacity-50"></i>
                    </a>
                    <a href="/Post/Create" class="btn btn-info text-white d-flex justify-content-between align-items-center py-2 px-3 rounded-3 shadow-sm hover-elevate">
                        <span class="fw-semibold"><i class="bi bi-pencil-square me-2"></i> Viết Bài Tin Tức</span>
                        <i class="bi bi-chevron-right opacity-50"></i>
                    </a>
                    <a href="/Order/Index" class="btn btn-success d-flex justify-content-between align-items-center py-2 px-3 rounded-3 shadow-sm hover-elevate">
                        <span class="fw-semibold"><i class="bi bi-cart-check me-2"></i> Quản Lý Đơn Hàng</span>
                        <i class="bi bi-chevron-right opacity-50"></i>
                    </a>
                </div>
            </div>

            <!-- SẢN PHẨM MỚI NHẤT -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-bottom-0 pt-4 pb-2 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-box me-2 text-danger"></i> SẢN PHẨM MỚI</h5>
                    <a href="/Product/Index" class="text-decoration-none small text-muted">Xem tất cả</a>
                </div>
                <div class="card-body pt-0">
                    <ul class="list-group list-group-flush">
                        @if (ViewBag.RecentProducts != null)
                        {
                            foreach (var product in ViewBag.RecentProducts)
                            {
                                <li class="list-group-item px-0 py-3 border-bottom d-flex align-items-center">
                                    <div class="bg-light rounded p-1 me-3 d-flex justify-content-center align-items-center" style="width: 50px; height: 50px; flex-shrink: 0;">
                                        <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/wine-placeholder.png" : product.ImageUrl)" alt="" style="max-width: 100%; max-height: 100%; object-fit: contain; mix-blend-mode: multiply;" onerror="this.src='https://placehold.co/100x100?text=Wine'" />
                                    </div>
                                    <div class="flex-grow-1 overflow-hidden">
                                        <h6 class="mb-1 text-dark fw-bold text-truncate-2" style="font-size: 0.9rem;">@product.Name</h6>
                                        <div class="d-flex justify-content-between align-items-center">
                                            <span class="text-danger fw-bold small">@String.Format("{0:N0} ₫", product.Price)</span>
                                            <span class="badge bg-light text-dark border">Kho: @product.StockQuantity</span>
                                        </div>
                                    </div>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item px-0 text-center text-muted py-4">Chưa có sản phẩm nào</li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>