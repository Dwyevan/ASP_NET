@{
    // Ép trang chủ sử dụng giao diện Admin có thanh Sidebar bên trái
    Layout = "_LayoutAdmin";
}

<div class="container mt-2">
    <h2 class="fw-bold text-primary mb-4">
        <i class="bi bi-speedometer2"></i> TỔNG QUAN HỆ THỐNG
    </h2>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card shadow border-0 border-start border-primary border-5 h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-primary text-uppercase mb-1">
                                Tổng Sản Phẩm
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800">
                                @ViewBag.TotalProducts
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-box-seam fs-1 text-primary opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0 border-start border-success border-5 h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-success text-uppercase mb-1">
                                Đơn Hàng Đã Đặt
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800">
                                @ViewBag.TotalOrders
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-cart-check fs-1 text-success opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0 border-start border-info border-5 h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-info text-uppercase mb-1">
                                Khách Hàng
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800">
                                @ViewBag.TotalCustomers
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-people fs-1 text-info opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card shadow border-0 border-start border-warning border-5 h-100 py-2">
                <div class="card-body">
                    <div class="row no-gutters align-items-center">
                        <div class="col mr-2">
                            <div class="text-xs fw-bold text-warning text-uppercase mb-1">
                                Tổng Doanh Thu
                            </div>
                            <div class="h3 mb-0 fw-bold text-gray-800 text-danger">
                                @(((decimal)ViewBag.TotalRevenue).ToString("#,##0")) đ
                            </div>
                        </div>
                        <div class="col-auto">
                            <i class="bi bi-currency-dollar fs-1 text-warning opacity-50"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>