@model IEnumerable<Cms.data.Entities.Customer>
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white p-3 border-bottom-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-primary text-uppercase mb-0">
                <i class="bi bi-people-fill me-2"></i>DANH SÁCH KHÁCH HÀNG
            </h5>
            <div class="d-flex gap-2">
                <form method="get" class="d-flex">
                    <div class="input-group input-group-sm">
                        <input name="keyword" class="form-control" placeholder="Tìm kiếm khách hàng..." value="@Context.Request.Query["keyword"]" />
                        <button class="btn btn-outline-secondary" type="submit" title="Tìm kiếm">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th class="text-start">Họ tên Khách hàng</th>
                            <th class="text-start">Email</th>
                            <th class="text-center">Số điện thoại</th>
                            <th class="text-center">Trạng thái</th>
                            <th style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-secondary">#@item.Id</td>
                                    <td class="text-start fw-bold text-dark">
                                        @item.FullName
                                        @if (item.Password != null && item.Password.StartsWith("[LOCKED]"))
                                        {
                                            <i class="bi bi-lock-fill text-danger ms-1" title="Tài khoản đang bị khóa"></i>
                                        }
                                    </td>
                                    <td class="text-start">@item.Email</td>
                                    <td class="text-center fw-semibold text-secondary">@item.Phone</td>
                                    <td class="text-center">
                                        @if (item.Password != null && item.Password.StartsWith("[LOCKED]"))
                                        {
                                            <span class="badge bg-danger rounded-pill"><i class="bi bi-lock-fill me-1"></i>Đã Khóa</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success rounded-pill"><i class="bi bi-check-circle-fill me-1"></i>Hoạt động</span>
                                        }
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white shadow-sm" title="Xem chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <form asp-action="ToggleLock" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                @if (item.Password != null && item.Password.StartsWith("[LOCKED]"))
                                                {
                                                    <button type="submit" class="btn btn-sm btn-success shadow-sm" title="Mở khóa tài khoản" onclick="return confirm('Bạn có chắc chắn muốn MỞ KHÓA cho tài khoản này?');">
                                                        <i class="bi bi-unlock-fill"></i>
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-sm btn-danger shadow-sm" title="Khóa tài khoản" onclick="return confirm('Khóa tài khoản này sẽ khiến khách hàng không thể đăng nhập. Bạn có chắc chắn?');">
                                                        <i class="bi bi-lock-fill"></i>
                                                    </button>
                                                }
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    <h5>Chưa có dữ liệu khách hàng!</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>