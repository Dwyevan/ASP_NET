@model IEnumerable<Cms.data.Entities.Customer>

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-2">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">DANH SÁCH KHÁCH HÀNG</h2>
    </div>

    <form method="get" class="row mb-4">
        <div class="col-md-9">
            <input name="keyword"
                   class="form-control"
                   placeholder="Nhập tên hoặc số điện thoại khách hàng để tìm kiếm..."
                   value="@Context.Request.Query["keyword"]" />
        </div>
        <div class="col-md-3">
            <button class="btn btn-primary w-100 fw-bold">
                <i class="bi bi-search me-1"></i> Tìm kiếm
            </button>
        </div>
    </form>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Họ tên Khách hàng</th>
                        <th>Email</th>
                        <th>Số điện thoại</th>
                        <th>Địa chỉ giao hàng</th>
                        <th style="width: 100px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">#@item.Id</td>
                                <td class="fw-bold text-dark">@item.FullName</td>
                                <td>@item.Email</td>
                                <td class="text-center fw-bold text-secondary">@item.Phone</td>
                                <td class="text-muted small">@item.Address</td>

                                <td class="text-center">
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger fw-bold" onclick="return confirm('Bạn có chắc chắn muốn xóa khách hàng này khỏi hệ thống?');">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-danger fw-bold py-4">
                                Chưa có dữ liệu khách hàng!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>