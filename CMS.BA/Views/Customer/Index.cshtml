@model IEnumerable<Cms.data.Entities.Customer>

<div class="container mt-4">

    <h2 class="text-primary">

        DANH SÁCH KHÁCH HÀNG

    </h2>

    <table class="table table-bordered table-hover">

        <thead class="table-dark">

            <tr>

                <th>ID</th>

                <th>Full Name</th>

                <th>Email</th>

                <th>Phone</th>

                <th>Address</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var item in Model)
            {

                <tr>

                    <td>@item.Id</td>

                    <td>@item.FullName</td>

                    <td>@item.Email</td>

                    <td>@item.Phone</td>

                    <td>@item.Address</td>

                </tr>

            }

        </tbody>

    </table>

</div>