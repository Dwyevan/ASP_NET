@model Cms.data.Entities.Customer
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-uppercase mb-0 text-primary">
            <i class="bi bi-person-badge me-2"></i>HỒ SƠ KHÁCH HÀNG: @Model.FullName
        </h4>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill shadow-sm">
            <i class="bi bi-arrow-left me-1"></i> Quay lại
        </a>
    </div>

    <div class="row">
        <!-- Thông tin cá nhân -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-header bg-white p-3 border-bottom-0 text-center pt-4">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center mx-auto mb-3 border shadow-sm" style="width: 100px; height: 100px; font-size: 3rem; color: #6c757d;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <h5 class="fw-bold mb-1 text-dark">@Model.FullName</h5>
                    @if (Model.Password != null && Model.Password.StartsWith("[LOCKED]"))
                    {
                        <span class="badge bg-danger rounded-pill mt-2 px-3 py-2"><i class="bi bi-lock-fill me-1"></i> TÀI KHOẢN ĐÃ BỊ KHÓA</span>
                    }
                    else
                    {
                        <span class="badge bg-success rounded-pill mt-2 px-3 py-2"><i class="bi bi-check-circle-fill me-1"></i> Đang hoạt động</span>
                    }
                </div>
                <div class="card-body bg-light">
                    <ul class="list-group list-group-flush rounded-3 shadow-sm">
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <span class="text-muted"><i class="bi bi-envelope-fill me-2"></i>Email</span>
                            <strong class="text-dark">@Model.Email</strong>
                        </li>
                        <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                            <span class="text-muted"><i class="bi bi-telephone-fill me-2"></i>Số điện thoại</span>
                            <strong class="text-dark">@Model.Phone</strong>
                        </li>
                        <li class="list-group-item p-3">
                            <span class="text-muted d-block mb-1"><i class="bi bi-geo-alt-fill me-2"></i>Địa chỉ mặc định</span>
                            <strong class="text-dark">@Model.Address</strong>
                        </li>
                    </ul>

                    <div class="mt-4 d-grid">
                        <form asp-action="ToggleLock" method="post" class="m-0">
                            <input type="hidden" name="id" value="@Model.Id" />
                            @if (Model.Password != null && Model.Password.StartsWith("[LOCKED]"))
                            {
                                <button type="submit" class="btn btn-success w-100 fw-bold shadow-sm" onclick="return confirm('Mở khóa cho tài khoản này?');">
                                    <i class="bi bi-unlock-fill me-2"></i> Mở khóa Tài khoản
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-outline-danger w-100 fw-bold" onclick="return confirm('Bạn có chắc chắn muốn khóa tài khoản này?');">
                                    <i class="bi bi-lock-fill me-2"></i> Khóa Tài khoản
                                </button>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Lịch sử mua hàng -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow-sm border-0 rounded-3 h-100">
                <div class="card-header bg-white p-3 border-bottom-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-clock-history me-2"></i>Lịch sử mua hàng</h5>
                    <span class="badge bg-primary rounded-pill px-3">@((Model.Orders != null) ? Model.Orders.Count() : 0) đơn hàng</span>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light text-center">
                                <tr>
                                    <th style="width: 80px;">Mã ĐH</th>
                                    <th>Ngày đặt</th>
                                    <th class="text-end">Tổng tiền</th>
                                    <th>Trạng thái</th>
                                    <th style="width: 100px;">Chi tiết</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Orders != null && Model.Orders.Any())
                                {
                                    foreach (var order in Model.Orders.OrderByDescending(o => o.OrderDate))
                                    {
                                        <tr>
                                            <td class="text-center fw-bold text-secondary">#@order.Id</td>
                                            <td class="text-center text-muted">@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                                            <td class="text-end fw-bold text-danger">@String.Format("{0:N0} ₫", order.TotalAmount)</td>
                                            <td class="text-center">
                                                @if (order.Status == 0) { <span class="badge bg-warning text-dark">Chờ duyệt (COD)</span> }
                                                else if (order.Status == 1) { <span class="badge bg-info text-dark">Đang giao</span> }
                                                else if (order.Status == 2) { <span class="badge bg-success">Đã xong</span> }
                                                else if (order.Status == 3) { <span class="badge bg-secondary">Đã hủy</span> }
                                                else if (order.Status == 10) { <span class="badge bg-warning text-dark">Chờ duyệt (MoMo)</span> }
                                                else if (order.Status == 11) { <span class="badge bg-info text-dark">Đang giao (MoMo)</span> }
                                                else if (order.Status == 12) { <span class="badge bg-success">Đã xong (MoMo)</span> }
                                                else if (order.Status == 13) { <span class="badge bg-danger">Yêu cầu hoàn tiền</span> }
                                                else if (order.Status == 14) { <span class="badge bg-secondary">Đã hoàn tiền</span> }
                                            </td>
                                            <td class="text-center">
                                                <a href="/Order/Details/@order.Id" class="btn btn-sm btn-outline-primary" title="Xem chi tiết đơn hàng">
                                                    <i class="bi bi-box-arrow-up-right"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5 text-muted">
                                            <i class="bi bi-cart-x fs-1 d-block mb-3 opacity-50"></i>
                                            Khách hàng này chưa có đơn hàng nào.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
