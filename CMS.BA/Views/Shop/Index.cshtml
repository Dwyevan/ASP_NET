@model IEnumerable<Cms.data.Entities.Product>

@{
    Layout = "_LayoutCustomer";
}

<div class="text-center mb-5">
    <h1 class="fw-bold text-primary display-5">SẢN PHẨM CÔNG NGHỆ NỔI BẬT</h1>
    <p class="text-muted">Khám phá các dòng điện thoại, laptop và phụ kiện mới nhất với giá cực ưu đãi!</p>
</div>

<div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden product-card">

                    <div class="bg-white p-3 text-center">
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name"
                             style="height: 180px; object-fit: contain;"
                             onerror="this.onerror=null; this.src='https://placehold.co/400x300?text=Tech+Gadget';" />
                    </div>

                    <div class="card-body d-flex flex-column bg-light">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-primary bg-opacity-10 text-primary fw-bold rounded-pill px-3 py-2">
                                @(item.CategoryProduct != null ? item.CategoryProduct.Name : "Đồ điện tử")
                            </span>
                        </div>

                        <h5 class="card-title fw-bold text-dark mb-1">@item.Name</h5>
                        <p class="card-text text-muted small mb-3 flex-grow-1" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @item.Description
                        </p>

                        <div class="d-flex justify-content-between align-items-end mt-auto">
                            <h5 class="text-danger fw-bold mb-0">@item.Price.ToString("#,##0") đ</h5>

                            <a asp-controller="Cart" asp-action="AddToCart" asp-route-id="@item.Id"
                               class="btn btn-outline-primary btn-sm rounded-circle shadow-sm"
                               style="width: 35px; height: 35px; line-height: 22px;" title="Thêm vào giỏ">
                                <i class="bi bi-cart-plus-fill"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center py-5">
            <h4 class="text-muted">Hiện tại cửa hàng đang cập nhật sản phẩm mới. Xin quay lại sau!</h4>
        </div>
    }
</div>

<style>
    .product-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15) !important;
        }
</style>