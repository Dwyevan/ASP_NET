<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Trị - CMS Backend</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f8f9fa;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529;
            color: white;
        }

            .sidebar .nav-link {
                color: #adbcca;
                font-weight: 500;
                padding: 12px 20px;
            }

                .sidebar .nav-link:hover, .sidebar .nav-link.active {
                    color: white;
                    background-color: #343a40;
                }

        .main-content {
            padding: 25px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <div class="col-md-3 col-lg-2 px-0 sidebar shadow">
                <div class="p-3 bg-dark text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-success mb-0"><i class="bi bi-speedometer2"></i> ADMIN PANEL</h4>
                </div>
                <ul class="nav flex-column mt-3">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door-fill me-2"></i> Trang chủ chính
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-box-seam-fill me-2"></i> Quản lý Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Order" asp-action="Index">
                            <i class="bi bi-cart-fill me-2"></i> Quản lý Đơn hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CategoriesProduct" asp-action="Index">
                            <i class="bi bi-tags-fill me-2"></i> Quản lý Danh mục
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            <i class="bi bi-people-fill me-2"></i> Quản lý Khách hàng
                        </a>
                    </li>
                </ul>
            </div>

            <div class="col-md-9 col-lg-10 px-0">
                <nav class="navbar navbar-expand navbar-light bg-white shadow-sm px-4 py-3">
                    <span class="navbar-brand mb-0 h1 fw-bold text-secondary">Hệ Thống Quản Lý Kinh Doanh trực tuyến</span>
                </nav>
                <div class="main-content">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>