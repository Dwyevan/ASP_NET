<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Trị - CMS Backend</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        body {
            background-color: #f4f6f9; /* Màu xám cực nhạt để làm nổi bật card */
            overflow-x: hidden;
        }

        .sidebar {
            min-height: 100vh;
            background-color: #212529; /* Màu than chì sang trọng */
            color: white;
        }

        .sidebar .nav-link {
            color: #adbcca;
            font-weight: 500;
            padding: 12px 20px;
            border-radius: 8px;
            margin: 4px 12px;
            transition: all 0.3s ease;
        }

        .sidebar .nav-link:hover {
            color: #ffffff;
            background-color: rgba(255, 255, 255, 0.1);
            transform: translateX(5px);
        }

        .sidebar .nav-link.active {
            color: #ffffff;
            background-color: #0d6efd;
            box-shadow: 0 4px 10px rgba(13, 110, 253, 0.3);
        }

        .topbar {
            background-color: #ffffff;
        }
    </style>
</head>
<body>
    <div class="container-fluid p-0">
        <div class="d-flex">
            <!-- Sidebar Cố Định Bên Trái -->
            <div class="sidebar shadow" style="width: 270px;">
                <div class="p-3 bg-dark text-center border-bottom border-secondary">
                    <h4 class="fw-bold text-light mb-0 py-2"><i class="bi bi-shield-lock"></i> ADMIN PANEL</h4>
                </div>
                <ul class="nav flex-column mt-3">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer me-2"></i> Bảng điều khiển
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Post" asp-action="Index">
                            <i class="bi bi-file-earmark-text-fill me-2"></i> Quản lý Bài viết
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Category" asp-action="Index">
                            <i class="bi bi-folder-fill me-2"></i> Danh mục Bài viết
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="User" asp-action="Index">
                            <i class="bi bi-person-badge-fill me-2"></i> Quản lý Thành viên
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-box-seam-fill me-2"></i> Quản lý Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CategoriesProduct" asp-action="Index">
                            <i class="bi bi-tags-fill me-2"></i> Danh mục Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Customer" asp-action="Index">
                            <i class="bi bi-people-fill me-2"></i> Quản lý Khách hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Order" asp-action="Index">
                            <i class="bi bi-cart-fill me-2"></i> Quản lý Đơn hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="OrderDetail" asp-action="Index">
                            <i class="bi bi-receipt me-2"></i> Chi tiết Đơn hàng
                        </a>
                    </li>
                </ul>
            </div>

            <!-- Vùng Nội Dung Chính Bên Phải -->
            <div class="flex-grow-1" style="width: calc(100% - 270px);">
                <!-- Topbar Navbar -->
                <nav class="navbar navbar-expand navbar-light topbar shadow-sm px-4 py-3 d-flex justify-content-between align-items-center">
                    <span class="navbar-brand mb-0 h5 fw-bold text-secondary">
                        <i class="bi bi-list fs-4 me-2"></i> CMS DASHBOARD
                    </span>
                    
                    <div class="d-flex align-items-center">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User.Identity.Name;
                            var role = User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "Thành viên";
                            
                            <span class="me-3 fw-semibold text-dark">
                                Chào, @fullName (@role)
                            </span>
                            <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger btn-sm rounded-pill px-3 shadow-sm">
                                <i class="bi bi-box-arrow-right"></i> Đăng xuất
                            </a>
                        }
                    </div>
                </nav>

                <!-- Page Content (RenderBody) -->
                <div class="main-content p-4">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- JS xử lý Highlight Menu đang được chọn -->
    <script>
        $(document).ready(function () {
            var path = window.location.pathname.toLowerCase();
            $('.sidebar .nav-link').each(function () {
                var href = $(this).attr('href').toLowerCase();
                if (href !== '/' && path.indexOf(href) === 0) {
                    $(this).addClass('active');
                } else if ((path === '/' || path === '/home/index') && href.indexOf('home') > -1) {
                    $(this).addClass('active');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>