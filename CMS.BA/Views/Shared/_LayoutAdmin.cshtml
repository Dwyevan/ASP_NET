<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hệ Thống Quản Trị - CMS Backend</title>
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body {
            background-color: #f8f9fa; 
            overflow-x: hidden;
            font-family: 'Inter', sans-serif;
        }

        /* Sidebar Modern UI */
        .sidebar {
            min-height: 100vh;
            background-color: #ffffff; /* Sáng sủa hơn */
            border-right: 1px solid rgba(0,0,0,0.05);
            z-index: 1000;
        }

        .sidebar-brand {
            padding: 1.5rem 1.5rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .sidebar-brand-icon {
            background: linear-gradient(310deg, #141727 0%, #3A416F 100%);
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sidebar .nav-link {
            color: #67748e;
            font-size: 0.9rem;
            font-weight: 500;
            padding: 10px 16px;
            border-radius: 8px;
            margin: 4px 16px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }

        .sidebar .nav-link .icon-box {
            background-color: #fff;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            color: #344767;
            transition: all 0.3s ease;
        }

        .sidebar .menu-heading {
            color: #adb5bd;
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: 700;
            margin: 20px 24px 8px;
        }

        .sidebar .nav-link:hover {
            color: #344767;
            background-color: #f8f9fa;
        }

        .sidebar .nav-link.active {
            color: #344767;
            background-color: #f8f9fa;
            font-weight: 600;
            box-shadow: inset 3px 0 0 #3A416F;
        }

        .sidebar .nav-link.active .icon-box {
            background: linear-gradient(310deg, #141727 0%, #3A416F 100%);
            color: white;
        }

        /* Topbar Modern UI */
        .topbar {
            background-color: rgba(255, 255, 255, 0.8) !important;
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(0,0,0,0.03);
            position: sticky;
            top: 0;
            z-index: 999;
        }
        
        .main-content-wrap {
            width: calc(100% - 270px);
            margin-left: 270px;
        }

    </style>
</head>
<body>
    <div class="d-flex">
        <!-- Sidebar Cố Định Bên Trái -->
        <div class="sidebar position-fixed" style="width: 270px;">
            <div class="sidebar-brand border-bottom">
                <div class="sidebar-brand-icon shadow-sm">
                    <i class="bi bi-hexagon-fill"></i>
                </div>
                <h5 class="fw-bold text-dark mb-0 ms-2" style="letter-spacing: 0.5px;">CMS ADMIN</h5>
            </div>
            
            @{
                var role = User?.Claims?.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value ?? "User";
                var isAdmin = role == "Admin";
            }

            <div class="mt-4 overflow-auto" style="height: calc(100vh - 80px);">
                <ul class="nav flex-column mb-5">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <div class="icon-box"><i class="bi bi-grid-1x2-fill"></i></div>
                            Bảng điều khiển
                        </a>
                    </li>

                    <li class="menu-heading">Kinh Doanh</li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Order" asp-action="Index">
                            <div class="icon-box text-warning"><i class="bi bi-receipt"></i></div>
                            Quản lý Đơn hàng
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Product" asp-action="Index">
                            <div class="icon-box text-info"><i class="bi bi-box-seam"></i></div>
                            Quản lý Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="CategoriesProduct" asp-action="Index">
                            <div class="icon-box text-secondary"><i class="bi bi-tags"></i></div>
                            Danh mục Sản phẩm
                        </a>
                    </li>

                    <li class="menu-heading">Nội Dung</li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Post" asp-action="Index">
                            <div class="icon-box text-success"><i class="bi bi-file-earmark-text"></i></div>
                            Quản lý Bài viết
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Category" asp-action="Index">
                            <div class="icon-box text-secondary"><i class="bi bi-folder2"></i></div>
                            Danh mục Bài viết
                        </a>
                    </li>

                    @if (isAdmin)
                    {
                        <li class="menu-heading">Hệ Thống</li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="User" asp-action="Index">
                                <div class="icon-box text-danger"><i class="bi bi-person-badge"></i></div>
                                Quản trị viên
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Customer" asp-action="Index">
                                <div class="icon-box text-primary"><i class="bi bi-people"></i></div>
                                Khách hàng
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>

        <!-- Vùng Nội Dung Chính Bên Phải -->
        <div class="main-content-wrap">
            <!-- Topbar Navbar -->
            <nav class="navbar navbar-expand-lg navbar-light topbar px-4 py-3 d-flex justify-content-between align-items-center">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb bg-transparent mb-0 pb-0 pt-1 px-0 me-sm-6 me-5">
                        <li class="breadcrumb-item text-sm"><a class="opacity-5 text-dark text-decoration-none" href="javascript:;">Trang chủ</a></li>
                        <li class="breadcrumb-item text-sm text-dark active fw-bold" aria-current="page">@ViewData["Title"]</li>
                    </ol>
                    <h6 class="font-weight-bolder mb-0">@ViewData["Title"]</h6>
                </nav>
                
                <div class="d-flex align-items-center">
                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        var fullName = User?.Claims?.FirstOrDefault(c => c.Type == "FullName")?.Value ?? User?.Identity?.Name ?? "Thành viên";
                        
                        <div class="dropdown">
                            <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                                <div class="bg-light rounded-circle p-2 me-2 d-flex align-items-center justify-content-center shadow-sm" style="width: 35px; height: 35px;">
                                    <i class="bi bi-person-fill text-secondary"></i>
                                </div>
                                <span class="d-none d-sm-inline mx-1 fw-semibold">@fullName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" aria-labelledby="dropdownUser1">
                                <li><a class="dropdown-item py-2" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <a asp-controller="Account" asp-action="Logout" class="dropdown-item py-2 text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i>Đăng xuất
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                </div>
            </nav>

            <!-- Page Content (RenderBody) -->
            <div class="container-fluid p-4">
                @RenderBody()
            </div>
            
            <!-- Footer -->
            <footer class="footer pt-3 pb-4 px-4">
                <div class="row align-items-center justify-content-lg-between">
                    <div class="col-lg-6 mb-lg-0 mb-4">
                        <div class="copyright text-center text-sm text-muted text-lg-start">
                            © <script>document.write(new Date().getFullYear())</script>,
                            Hệ thống quản trị nội dung <i class="bi bi-suit-heart-fill text-danger"></i> DuyCMS.
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- JS xử lý Highlight Menu đang được chọn -->
    <script>
        $(document).ready(function () {
            var path = window.location.pathname.toLowerCase();
            $('.sidebar .nav-link').each(function () {
                var href = $(this).attr('href').toLowerCase();
                if (href !== '/' && path.indexOf(href) === 0) {
                    $(this).addClass('active');
                } else if ((path === '/' || path === '/home/index') && href.indexOf('home') > -1) {
                    $(this).addClass('active');
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>