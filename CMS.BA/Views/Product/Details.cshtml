@model Cms.data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết Sản phẩm";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm rounded-3 border-0">
                <div class="card-header bg-white p-3 border-bottom-0 d-flex justify-content-between align-items-center">
                    <h4 class="fw-bold mb-0 text-info">
                        <i class="bi bi-info-circle me-2"></i>CHI TIẾT SẢN PHẨM
                    </h4>
                    <a asp-action="Index" class="btn btn-secondary btn-sm shadow-sm">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
                
                <div class="card-body p-4 bg-light">
                    <div class="row align-items-center">
                        <!-- Cột Hình ảnh -->
                        <div class="col-md-5 text-center mb-4 mb-md-0">
                            <div class="bg-white p-2 border rounded shadow-sm">
                                <img src="@Model.ImageUrl" 
                                     alt="@Model.Name"
                                     class="img-fluid rounded"
                                     style="max-height: 350px; object-fit: contain;"
                                     onerror="this.src='https://placehold.co/400x350?text=No+Image'" />
                            </div>
                        </div>
                        
                        <!-- Cột Thông tin -->
                        <div class="col-md-7">
                            <h2 class="fw-bold text-dark mb-3">@Model.Name</h2>
                            <h4 class="text-danger fw-bold mb-4">@Model.Price.ToString("#,##0") ₫</h4>
                            
                            <table class="table table-borderless table-sm fs-5">
                                <tbody>
                                    <tr>
                                        <th style="width: 35%;" class="text-secondary"><i class="bi bi-upc-scan me-2"></i>Mã sản phẩm:</th>
                                        <td class="fw-bold">@Model.Id</td>
                                    </tr>
                                    <tr>
                                        <th class="text-secondary"><i class="bi bi-folder2-open me-2"></i>Danh mục:</th>
                                        <td>
                                            <span class="badge bg-info text-white">@(Model.CategoryProduct != null ? Model.CategoryProduct.Name : "Không có")</span>
                                        </td>
                                    </tr>
                                    <tr>
                                        <th class="text-secondary"><i class="bi bi-box-seam me-2"></i>Tồn kho:</th>
                                        <td>
                                            <span class="badge @(Model.StockQuantity > 0 ? "bg-success" : "bg-danger")">@Model.StockQuantity</span>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                            
                            <hr />
                            <div class="mt-3">
                                <h5 class="fw-bold text-secondary mb-2"><i class="bi bi-card-text me-2"></i>Mô tả chi tiết:</h5>
                                <p class="text-dark lh-lg" style="white-space: pre-line;">@Model.Description</p>
                            </div>
                            
                            <div class="mt-4 pt-3 d-flex gap-2 border-top">
                                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning shadow-sm px-4">
                                    <i class="bi bi-pencil-square"></i> Sửa sản phẩm
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
