@model Cms.data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chi tiết Sản phẩm";
}

<div class="row">
    <!-- Header Controls -->
    <div class="col-12 mb-4 d-flex justify-content-between align-items-center">
        <div>
            <h4 class="mb-0 fw-bold text-dark">Thông tin chi tiết</h4>
            <p class="text-sm text-secondary mb-0">Quản lý và cập nhật thông số sản phẩm</p>
        </div>
        <div>
            <a asp-action="Index" class="btn btn-outline-secondary shadow-sm me-2">
                <i class="bi bi-arrow-left me-1"></i> Trở về
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning shadow-sm">
                <i class="bi bi-pencil-square me-1"></i> Chỉnh sửa
            </a>
        </div>
    </div>

    <!-- Cột Trái: Ảnh và Trạng Thái -->
    <div class="col-lg-4 mb-4">
        <div class="card h-100 border-0 shadow-sm">
            <div class="card-header pb-0 p-3 bg-white border-0 text-center">
                <h6 class="mb-0 text-uppercase text-secondary text-xs fw-bolder">Hình ảnh đại diện</h6>
            </div>
            <div class="card-body p-4 text-center">
                <div class="position-relative d-inline-block">
                    <img src="@Model.ImageUrl" 
                         alt="@Model.Name" 
                         class="img-fluid img-thumbnail-soft mb-3" 
                         style="max-height: 300px; object-fit: contain; width: 100%;" 
                         onerror="this.src='https://placehold.co/400x350?text=No+Image'" />
                         
                    @if (Model.StockQuantity > 0)
                    {
                        <span class="badge badge-soft-success position-absolute" style="top: 10px; right: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                            <i class="bi bi-check-circle-fill me-1"></i> Còn hàng
                        </span>
                    }
                    else
                    {
                        <span class="badge badge-soft-danger position-absolute" style="top: 10px; right: 10px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                            <i class="bi bi-x-circle-fill me-1"></i> Hết hàng
                        </span>
                    }
                </div>
                
                <h5 class="fw-bold text-dark mt-3 mb-1">ID: @Model.Id</h5>
                <p class="text-sm text-secondary">@(Model.CategoryProduct != null ? Model.CategoryProduct.Name : "Chưa phân loại")</p>
                
                <div class="d-grid mt-4">
                    <a href="@Model.ImageUrl" target="_blank" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-zoom-in me-1"></i> Xem ảnh gốc
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Cột Phải: Thông tin chi tiết -->
    <div class="col-lg-8 mb-4">
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header pb-0 p-3 bg-white border-0">
                <h6 class="mb-0 text-uppercase text-secondary text-xs fw-bolder"><i class="bi bi-info-square me-2"></i>Thông số tổng quan</h6>
            </div>
            <div class="card-body p-4">
                <h3 class="fw-bolder text-dark mb-4" style="letter-spacing: -0.5px;">@Model.Name</h3>
                
                <div class="row g-4 mb-4">
                    <!-- Giá bán -->
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3 d-flex align-items-center border" style="border-color: rgba(0,0,0,0.05) !important;">
                            <div class="bg-white text-warning rounded-circle d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 48px; height: 48px;">
                                <i class="bi bi-tag-fill fs-4"></i>
                            </div>
                            <div>
                                <p class="text-sm mb-0 text-secondary fw-semibold">Giá bán niêm yết</p>
                                <h4 class="mb-0 fw-bold text-danger">@Model.Price.ToString("#,##0") <small class="text-secondary fs-6">₫</small></h4>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Tồn kho -->
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded-3 d-flex align-items-center border" style="border-color: rgba(0,0,0,0.05) !important;">
                            <div class="bg-white text-info rounded-circle d-flex align-items-center justify-content-center shadow-sm me-3" style="width: 48px; height: 48px;">
                                <i class="bi bi-box-seam fs-4"></i>
                            </div>
                            <div>
                                <p class="text-sm mb-0 text-secondary fw-semibold">Số lượng trong kho</p>
                                <h4 class="mb-0 fw-bold text-dark">@Model.StockQuantity <small class="text-secondary fs-6">sản phẩm</small></h4>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-header pb-0 p-3 bg-white border-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 text-uppercase text-secondary text-xs fw-bolder"><i class="bi bi-file-text me-2"></i>Nội dung mô tả</h6>
            </div>
            <div class="card-body p-4">
                @if (string.IsNullOrEmpty(Model.Description))
                {
                    <div class="text-center py-4 bg-light rounded">
                        <i class="bi bi-journal-x text-secondary fs-1 mb-2"></i>
                        <p class="text-secondary mb-0">Chưa có mô tả cho sản phẩm này.</p>
                    </div>
                }
                else
                {
                    <div class="p-4 bg-light rounded-3 border" style="border-color: rgba(0,0,0,0.05) !important;">
                        <p class="text-dark lh-lg mb-0" style="white-space: pre-line; font-size: 0.95rem;">@Model.Description</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
