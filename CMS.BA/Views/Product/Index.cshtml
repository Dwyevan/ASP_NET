@model IEnumerable<Cms.data.Entities.Product>

<table class="table">

    <thead>

        <tr>

            <th>ID</th>

            <th>Name</th>

            <th>Price</th>

        </tr>

    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.Id</td>

                <td>@item.Name</td>

                <td>@item.Price</td>

            </tr>
        }

    </tbody>

</table>