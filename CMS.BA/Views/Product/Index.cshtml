@model IEnumerable<Cms.data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm rounded-3 border-0">
        <div class="card-header bg-white p-3 border-bottom-0">
            <div class="d-flex justify-content-between align-items-center">
                <h4 class="fw-bold mb-0 text-primary text-uppercase">
                    <i class="bi bi-box-seam me-2"></i>QUẢN LÝ SẢN PHẨM
                </h4>
                
                <div class="d-flex gap-3 align-items-center">
                    <!-- Search Bar -->
                    <form class="d-flex" asp-action="Index" method="get">
                        <div class="input-group input-group-sm">
                            <input type="text" name="keyword" class="form-control" placeholder="Tìm kiếm sản phẩm..." value="@Context.Request.Query["keyword"]" aria-label="Tìm kiếm">
                            <button class="btn btn-outline-secondary" type="submit" title="Tìm kiếm">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </form>
                    
                    <!-- Nút Thêm mới -->
                    <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm text-nowrap">
                        <i class="bi bi-plus-circle me-1"></i> Thêm sản phẩm
                    </a>
                </div>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered align-middle text-center mb-0">
                    <thead class="table-light text-center fw-bold">
                        <tr>
                            <th style="width: 5%;">ID</th>
                            <th style="width: 15%;">Ảnh</th>
                            <th style="width: 20%;" class="text-start">Tên sản phẩm</th>
                            <th style="width: 20%;" class="text-start">Mô tả</th>
                            <th style="width: 10%;">Giá bán</th>
                            <th style="width: 5%;">Kho</th>
                            <th style="width: 10%;">Danh mục</th>
                            <th style="width: 15%;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-semibold text-secondary">@item.Id</td>
                                    <td>
                                        <img src="@item.ImageUrl" 
                                             alt="@item.Name"
                                             class="img-thumbnail border border-primary-subtle rounded"
                                             style="width: 100px; height: 80px; object-fit: cover;"
                                             onerror="this.src='https://placehold.co/100x80?text=No+Image'" />
                                    </td>
                                    <td class="text-start fw-bold text-dark">@item.Name</td>
                                    <td class="text-start">
                                        <span class="text-truncate d-inline-block text-muted" style="max-width: 180px;" title="@item.Description">
                                            @item.Description
                                        </span>
                                    </td>
                                    <td class="text-danger fw-bold">@item.Price.ToString("#,##0") đ</td>
                                    <td>
                                        <span class="badge @(item.StockQuantity > 0 ? "bg-success" : "bg-danger")">@item.StockQuantity</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-white">@(item.CategoryProduct != null ? item.CategoryProduct.Name : "Không có")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex justify-content-center gap-2">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white shadow-sm" title="Xem chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm text-dark shadow-sm" title="Chỉnh sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm shadow-sm" title="Xóa sản phẩm" onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này không?');">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 text-secondary opacity-50"></i>
                                    <h5>Không tìm thấy sản phẩm nào.</h5>
                                    <p class="mb-0">Hãy nhấn "Thêm sản phẩm" hoặc thử tìm kiếm với từ khóa khác!</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>