@model IEnumerable<Cms.data.Entities.Product>
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Sản phẩm";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white p-3 border-bottom-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-primary text-uppercase mb-0">
                <i class="bi bi-box-seam me-2"></i>QUẢN LÝ SẢN PHẨM
            </h5>
            <div class="d-flex gap-3 align-items-center">
                <form class="d-flex" asp-action="Index" method="get">
                    <div class="input-group input-group-sm">
                        <input type="text" name="keyword" class="form-control" placeholder="Tìm kiếm sản phẩm..." value="@Context.Request.Query["keyword"]" aria-label="Tìm kiếm">
                        <button class="btn btn-outline-secondary" type="submit" title="Tìm kiếm">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
                <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm text-nowrap">
                    <i class="bi bi-plus-circle me-1"></i> Thêm mới
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th style="width: 100px;">Ảnh</th>
                            <th class="text-start">Tên sản phẩm</th>
                            <th class="text-start">Mô tả</th>
                            <th class="text-end">Giá bán</th>
                            <th class="text-center">Kho</th>
                            <th class="text-center">Danh mục</th>
                            <th style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-secondary">#@item.Id</td>
                                    <td class="text-center">
                                        <img src="@item.ImageUrl" alt="@item.Name" class="img-thumbnail border-primary-subtle rounded" style="width: 60px; height: 60px; object-fit: cover;" onerror="this.src='https://placehold.co/60x60?text=No+Image'" />
                                    </td>
                                    <td class="text-start fw-bold text-dark">@item.Name</td>
                                    <td class="text-start text-muted">
                                        <span class="d-inline-block text-truncate" style="max-width: 180px;" title="@item.Description">
                                            @item.Description
                                        </span>
                                    </td>
                                    <td class="text-end text-danger fw-bold">@String.Format("{0:N0} ₫", item.Price)</td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill @(item.StockQuantity > 0 ? "bg-success" : "bg-danger")">@item.StockQuantity</span>
                                    </td>
                                    <td class="text-center">
                                        <span class="badge rounded-pill bg-info text-white">@(item.CategoryProduct != null ? item.CategoryProduct.Name : "Không có")</span>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white shadow-sm" title="Chi tiết">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning text-dark shadow-sm" title="Sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger shadow-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa sản phẩm này?');">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    <h5>Không tìm thấy sản phẩm nào!</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>