@model IEnumerable<Cms.data.Entities.CategoryProduct>

@{
    // ÁP DỤNG LAYOUT ADMIN CHO ĐỒNG BỘ HỆ THỐNG
    Layout = "_LayoutAdmin";
}

<div class="container mt-2">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">
            DANH SÁCH CATEGORY PRODUCT
        </h2>
        <a asp-action="Create" class="btn btn-success fw-bold">
            <i class="bi bi-plus-circle-fill me-1"></i> Thêm danh mục
        </a>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover align-middle mb-0">
                <thead class="table-dark text-center">
                    <tr>
                        <th style="width: 80px;">ID</th>
                        <th>Name</th>
                        <th>Description</th>
                        <th style="width: 180px;">Chức năng</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center fw-bold">#@item.Id</td>
                                <td class="fw-bold text-dark">@item.Name</td>
                                <td class="text-muted">@item.Description</td>

                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning fw-bold text-dark me-1">
                                        <i class="bi bi-pencil-square"></i> Sửa
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger fw-bold" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục này?');">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center text-danger fw-bold py-4">
                                Chưa có danh mục nào trong hệ thống!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>