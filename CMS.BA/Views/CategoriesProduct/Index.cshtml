@model IEnumerable<Cms.data.Entities.CategoryProduct>
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white p-3 border-bottom-0 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold text-primary text-uppercase mb-0">
                <i class="bi bi-tags-fill me-2"></i>DANH MỤC SẢN PHẨM
            </h5>
            <a asp-action="Create" class="btn btn-success btn-sm rounded-pill px-3 shadow-sm text-nowrap">
                <i class="bi bi-plus-circle me-1"></i> Thêm mới
            </a>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-center">
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th class="text-start">Tên danh mục</th>
                            <th class="text-start">Mô tả</th>
                            <th style="width: 150px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-secondary">#@item.Id</td>
                                    <td class="text-start fw-bold text-dark">@item.Name</td>
                                    <td class="text-start text-muted">@item.Description</td>
                                    <td>
                                        <div class="d-flex gap-2 justify-content-center">
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning shadow-sm text-dark" title="Sửa">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger shadow-sm" title="Xóa" onclick="return confirm('Bạn có chắc chắn muốn xóa danh mục sản phẩm này?');">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-3 opacity-50"></i>
                                    <h5>Chưa có danh mục sản phẩm nào!</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>