@model Cms.data.Entities.CategoryProduct

@{
    Layout = "_LayoutAdmin";
}

<div class="container mt-2">
    <h2 class="fw-bold text-success mb-4"><i class="bi bi-plus-circle"></i> THÊM MỚI DANH MỤC</h2>

    <div class="card shadow">
        <div class="card-body">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục (VD: Đồ uống có ga, Rượu vang...)" required autofocus />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Mô tả chi tiết</label>
                    <textarea asp-for="Description" rows="4" class="form-control" placeholder="Nhập mô tả cho danh mục này..."></textarea>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success fw-bold px-4 me-2">
                        <i class="bi bi-save"></i> Lưu danh mục
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4">
                        <i class="bi bi-arrow-return-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>