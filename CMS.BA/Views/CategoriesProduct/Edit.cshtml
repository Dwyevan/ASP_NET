@model Cms.data.Entities.CategoryProduct
@{
    Layout = "_LayoutAdmin";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-header bg-white p-3 border-bottom">
                    <h5 class="fw-bold text-dark mb-0">CẬP NHẬT DANH MỤC SẢN PHẨM</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-bold text-dark">Tên danh mục <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control" placeholder="Nhập tên danh mục..." required />
                        </div>
                        <div class="mb-3">
                            <label asp-for="Description" class="form-label fw-bold text-dark">Mô tả chi tiết</label>
                            <textarea asp-for="Description" rows="4" class="form-control" placeholder="Nhập mô tả cho danh mục này..."></textarea>
                        </div>
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Cập nhật</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>